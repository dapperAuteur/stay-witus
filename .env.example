# ── Database (Neon) ──────────────────────────────────────────────────────────
DATABASE_URL=

# ── Auth (Better Auth — identity workstream) ────────────────────────────────
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# ── Email (Mailgun; per-tenant `from` comes from the tenant row) ────────────
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
MAILGUN_REGION=us
MAIL_FROM="Stay.WitUS <no-reply@mail.stay.witus.online>"

# ── Platform billing (BAM's accounts — B2B fees from tenant owners) ─────────
# BAM's Stripe (B4C LLC): card payments for platform invoices.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# BAM's MoMo receiving number shown on MoMo invoices (E.164, e.g. +233...).
PLATFORM_MOMO_NUMBER=
PLATFORM_MOMO_NAME=

# ── Guest payments (per-tenant; keys live in tenant payment config) ─────────
# Ghana tenants: Paystack. Stripe-country tenants: their own Stripe keys.
# Scaffold convention: tenant config stores an env-var NAME (secretRef), the
# actual secret lives here — e.g. TENANT_OSU_PAYSTACK_SECRET=sk_...

# ── Media (Cloudinary — ecosystem media vendor) ─────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Domain management (lifted witus-learn admin/domains) ────────────────────
VERCEL_DOMAINS_TOKEN=
VERCEL_PROJECT_ID=
VERCEL_TEAM_ID=

# ── WitUS ecosystem wiring ───────────────────────────────────────────────────
WITUS_INBOX_URL=
WITUS_INBOX_HMAC_SECRET=
OUTBOX_URL=
OUTBOX_HMAC_SECRET=
OUTBOX_TRIGGER_ENABLED=false

# ── Ops ──────────────────────────────────────────────────────────────────────
CRON_SECRET=
ADMIN_NOTIFY_EMAIL=
# Temporary guard for /platform until the Better Auth platform-owner gate ships.
PLATFORM_BOOTSTRAP=false
