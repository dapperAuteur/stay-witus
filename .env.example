# ══════════════════════════════════════════════════════════════════════════
# Stay.WitUS environment variables
# Copy to .env.local and fill. Legend:
#   [YOU]     you provide the value (account you own)
#   [VERCEL]  auto-set by a Vercel integration; pull with `vercel env pull`
#   [GEN]     generate it (command shown)
#   [LATER]   not needed until that workstream ships; safe to leave empty
# ══════════════════════════════════════════════════════════════════════════

# ── Database (Neon via Vercel Marketplace — your integration uses the
#    STORAGE_ prefix; verify exact names in Vercel → Project → Env Vars) ─────
STORAGE_DATABASE_URL=            # [VERCEL] pooled connection string
# DATABASE_URL=                  # fallback name for local/manual setups only

# ── Auth (Better Auth — identity workstream) ────────────────────────────────
BETTER_AUTH_SECRET=              # [GEN] openssl rand -base64 32
BETTER_AUTH_URL=http://localhost:3000   # [YOU] prod: https://stay.witus.online

# ── Email (Mailgun; per-tenant `from` comes from the tenant row) ────────────
MAILGUN_API_KEY=                 # [YOU] Mailgun dashboard → API keys
MAILGUN_DOMAIN=                  # [YOU] e.g. mail.stay.witus.online (after DNS verify)
MAILGUN_REGION=us                # [YOU] us | eu — match your Mailgun account
MAIL_FROM="Stay.WitUS <no-reply@mail.stay.witus.online>"   # [YOU] platform default sender

# ── PLATFORM BILLING: how tenant owners pay YOU ─────────────────────────────
# Card rail — YOUR Stripe (B4C LLC). Clients never bring Stripe keys for this.
STRIPE_SECRET_KEY=               # [YOU] your Stripe → Developers → API keys
STRIPE_WEBHOOK_SECRET=           # [YOU] created when the billing webhook ships [LATER]
# MoMo rail — YOUR receiving MoMo. Shown on invoices with a unique reference;
# the client sends from THEIR MoMo and taps "I've sent it"; you confirm in
# /platform/billing. There is NO env var for a client's MoMo — the payer's
# number is theirs and never enters our config.
PLATFORM_MOMO_NUMBER=            # [YOU] your MoMo number, E.164, e.g. +23324xxxxxxx
PLATFORM_MOMO_NAME=              # [YOU] the registered name payers will see, must match

# ── GUEST PAYMENTS: how guests pay each hotel (NOT env-per-hotel) ───────────
# Per-tenant config lives in the tenants.payment row (provider paystack|stripe,
# public key, currency). Only each tenant's SECRET key goes in env, named by
# the row's secretRef. Convention: TENANT_<SLUG>_<PROVIDER>_SECRET. Example:
# TENANT_OSU_PAYSTACK_SECRET=    # [YOU per customer] from the HOTEL's Paystack
# A hotel's MoMo settlement is configured inside ITS Paystack account
# (Paystack pays out to their bank/MoMo) — never in our env.

# ── Media (Cloudinary — ecosystem media vendor) ─────────────────────────────
CLOUDINARY_CLOUD_NAME=           # [YOU] existing ecosystem Cloudinary account
CLOUDINARY_API_KEY=              # [YOU]
CLOUDINARY_API_SECRET=           # [YOU]

# ── Domain management (lifted witus-learn /admin/domains) ───────────────────
VERCEL_DOMAINS_TOKEN=            # [YOU] Vercel account → Settings → Tokens [LATER]
VERCEL_PROJECT_ID=               # [VERCEL] project settings, or .vercel/project.json after `vercel link`
VERCEL_TEAM_ID=                  # [YOU] only if the project lives in a team

# ── WitUS ecosystem wiring ───────────────────────────────────────────────────
WITUS_INBOX_URL=                 # [YOU] witus-inbox ingest URL [LATER]
WITUS_INBOX_HMAC_SECRET=         # [GEN] shared with witus-inbox INGEST_SOURCES [LATER]
OUTBOX_URL=                      # [YOU] [LATER]
OUTBOX_HMAC_SECRET=              # [GEN] [LATER]
OUTBOX_TRIGGER_ENABLED=false     # keep false until outbox wiring is reviewed

# ── Ops ──────────────────────────────────────────────────────────────────────
CRON_SECRET=                     # [GEN] openssl rand -hex 32 — gates /api/cron/daily
ADMIN_NOTIFY_EMAIL=              # [YOU] where support-thread notifications land (you)
PLATFORM_BOOTSTRAP=false         # true ONLY in your own env to preview /platform pre-auth
